# kashi — top-level test entry (referenced by cyrius.cyml [build].test).
# Runs the freestanding font-data core tests plus library-skeleton checks.
# Uses the stdlib assert harness (assert / assert_eq / assert_summary) so
# the summary line is the canonical "N passed, M failed" CI greps for.
#
# Note: the code UNDER TEST (src/font_data.cyr) is freestanding — these
# tests link stdlib only for the assertion harness, never the core itself.
# Add new cases here or in tests/kashi.tcyr.

include "src/lib.cyr"

# --- font_data core: identity / metadata ---

fn test_metadata() {
    test_group("metadata");
    assert_eq(kashi_font_width(KASHI_FONT_VGA_8X16), 8, "vga width 8");
    assert_eq(kashi_font_height(KASHI_FONT_VGA_8X16), 16, "vga height 16");
    assert_eq(kashi_font_first(KASHI_FONT_VGA_8X16), 0x20, "vga first 0x20");
    assert_eq(kashi_font_count(KASHI_FONT_VGA_8X16), 224, "vga count 224");

    assert_eq(kashi_font_width(KASHI_FONT_CGA_8X8), 8, "cga width 8");
    assert_eq(kashi_font_height(KASHI_FONT_CGA_8X8), 8, "cga height 8");
    assert_eq(kashi_font_first(KASHI_FONT_CGA_8X8), 0x20, "cga first 0x20");
    assert_eq(kashi_font_count(KASHI_FONT_CGA_8X8), 224, "cga count 224");

    assert_eq(kashi_font_width(99), 0, "unknown width 0");
    assert_eq(kashi_font_height(99), 0, "unknown height 0");
    assert_eq(kashi_font_first(99), 0, "unknown first 0");
    assert_eq(kashi_font_count(99), 0, "unknown count 0");
    return 0;
}

# --- font_data core: encoded-range gate ---

fn test_encoded_gate() {
    test_group("encoded gate");
    assert_eq(kashi_glyph_encoded(0x1F), 0, "0x1F not encoded");
    assert_eq(kashi_glyph_encoded(0x20), 1, "0x20 encoded");
    assert_eq(kashi_glyph_encoded(0x41), 1, "A encoded");
    assert_eq(kashi_glyph_encoded(0x7F), 1, "0x7F encoded");
    assert_eq(kashi_glyph_encoded(0x80), 1, "0x80 encoded (CP437)");
    assert_eq(kashi_glyph_encoded(0xFF), 1, "0xFF encoded (last CP437)");
    assert_eq(kashi_glyph_encoded(0x100), 0, "0x100 not encoded");
    assert_eq(kashi_glyph_encoded(0), 0, "NUL not encoded");
    return 0;
}

# --- font_data core: exact byte fidelity vs agnos fb_console.cyr source ---
#
# These literals are read straight from the published tables. If kashi's
# extraction ever drifts from the bytes agnos renders, these fail.

fn test_vga_8x16_bytes() {
    test_group("vga 8x16 bytes");
    # space (0x20) — all 16 rows blank.
    var i = 0;
    var space_blank = 1;
    while (i < 16) {
        if (kashi_glyph_row(KASHI_FONT_VGA_8X16, 0x20, i) != 0) { space_blank = 0; }
        i = i + 1;
    }
    assert_eq(space_blank, 1, "vga space all-blank");

    # 'A' (0x41) = hi 0x000010386CC6C6FE, lo 0xC6C6C6C600000000.
    # Rows: 00 00 10 38 6C C6 C6 FE | C6 C6 C6 C6 00 00 00 00.
    assert_eq(kashi_glyph_row(KASHI_FONT_VGA_8X16, 0x41, 0), 0x00, "vga A row0");
    assert_eq(kashi_glyph_row(KASHI_FONT_VGA_8X16, 0x41, 2), 0x10, "vga A row2");
    assert_eq(kashi_glyph_row(KASHI_FONT_VGA_8X16, 0x41, 3), 0x38, "vga A row3");
    assert_eq(kashi_glyph_row(KASHI_FONT_VGA_8X16, 0x41, 4), 0x6C, "vga A row4");
    assert_eq(kashi_glyph_row(KASHI_FONT_VGA_8X16, 0x41, 5), 0xC6, "vga A row5");
    assert_eq(kashi_glyph_row(KASHI_FONT_VGA_8X16, 0x41, 7), 0xFE, "vga A row7");
    assert_eq(kashi_glyph_row(KASHI_FONT_VGA_8X16, 0x41, 8), 0xC6, "vga A row8");
    assert_eq(kashi_glyph_row(KASHI_FONT_VGA_8X16, 0x41, 11), 0xC6, "vga A row11");
    assert_eq(kashi_glyph_row(KASHI_FONT_VGA_8X16, 0x41, 12), 0x00, "vga A row12");
    assert_eq(kashi_glyph_row(KASHI_FONT_VGA_8X16, 0x41, 15), 0x00, "vga A row15");

    # '0' (0x30) = hi 0x0000386CC6C6D6D6, lo 0xC6C66C3800000000.
    assert_eq(kashi_glyph_row(KASHI_FONT_VGA_8X16, 0x30, 2), 0x38, "vga 0 row2");
    assert_eq(kashi_glyph_row(KASHI_FONT_VGA_8X16, 0x30, 6), 0xD6, "vga 0 row6");
    assert_eq(kashi_glyph_row(KASHI_FONT_VGA_8X16, 0x30, 7), 0xD6, "vga 0 row7");
    assert_eq(kashi_glyph_row(KASHI_FONT_VGA_8X16, 0x30, 10), 0x6C, "vga 0 row10");

    # '_' (0x5F) = hi 0, lo 0x0000000000FF0000 -> 0xFF lands at row 13
    # ((lo>>16)&0xFF), all other rows blank (underscore near the baseline).
    assert_eq(kashi_glyph_row(KASHI_FONT_VGA_8X16, 0x5F, 0), 0x00, "vga _ row0");
    assert_eq(kashi_glyph_row(KASHI_FONT_VGA_8X16, 0x5F, 10), 0x00, "vga _ row10");
    assert_eq(kashi_glyph_row(KASHI_FONT_VGA_8X16, 0x5F, 13), 0xFF, "vga _ row13");

    # '~' (0x7E) = hi 0x0076DC0000000000, lo 0.
    assert_eq(kashi_glyph_row(KASHI_FONT_VGA_8X16, 0x7E, 1), 0x76, "vga ~ row1");
    assert_eq(kashi_glyph_row(KASHI_FONT_VGA_8X16, 0x7E, 2), 0xDC, "vga ~ row2");
    assert_eq(kashi_glyph_row(KASHI_FONT_VGA_8X16, 0x7E, 3), 0x00, "vga ~ row3");

    # --- CP437 high half (added in 0.4.0) — lock transcription against the
    # public-domain Linux font_8x16.c source. Spot-checks across distinctive
    # glyphs: solid block, dither, line-art, accented letter, end-of-table.
    # 0xDB '█' full block — every row 0xFF.
    assert_eq(kashi_glyph_row(KASHI_FONT_VGA_8X16, 0xDB, 0), 0xFF, "vga 0xDB block r0");
    assert_eq(kashi_glyph_row(KASHI_FONT_VGA_8X16, 0xDB, 15), 0xFF, "vga 0xDB block r15");
    # 0xB0 '░' light shade — alternating 0x11 / 0x44 dither rows.
    assert_eq(kashi_glyph_row(KASHI_FONT_VGA_8X16, 0xB0, 0), 0x11, "vga 0xB0 dither r0");
    assert_eq(kashi_glyph_row(KASHI_FONT_VGA_8X16, 0xB0, 1), 0x44, "vga 0xB0 dither r1");
    # 0xC9 '╔' double upper-left corner — row 5 = 0x3F, row 8 onward = 0x36.
    assert_eq(kashi_glyph_row(KASHI_FONT_VGA_8X16, 0xC9, 5), 0x3F, "vga 0xC9 corner r5");
    assert_eq(kashi_glyph_row(KASHI_FONT_VGA_8X16, 0xC9, 8), 0x36, "vga 0xC9 corner r8");
    # 0xCD '═' double horizontal — rows 5 and 7 are 0xFF, others 0.
    assert_eq(kashi_glyph_row(KASHI_FONT_VGA_8X16, 0xCD, 5), 0xFF, "vga 0xCD hline r5");
    assert_eq(kashi_glyph_row(KASHI_FONT_VGA_8X16, 0xCD, 6), 0x00, "vga 0xCD hline r6");
    assert_eq(kashi_glyph_row(KASHI_FONT_VGA_8X16, 0xCD, 7), 0xFF, "vga 0xCD hline r7");
    # 0xE9 'Θ' Greek capital theta — crossbar row 6 = 0xFE.
    assert_eq(kashi_glyph_row(KASHI_FONT_VGA_8X16, 0xE9, 6), 0xFE, "vga 0xE9 theta r6");
    # 0xFF — last cell, intentionally blank.
    assert_eq(kashi_glyph_row(KASHI_FONT_VGA_8X16, 0xFF, 0), 0x00, "vga 0xFF blank");
    return 0;
}

fn test_cga_8x8_bytes() {
    test_group("cga 8x8 bytes");
    # space (0x20) — all 8 rows blank.
    var i = 0;
    var space_blank = 1;
    while (i < 8) {
        if (kashi_glyph_row(KASHI_FONT_CGA_8X8, 0x20, i) != 0) { space_blank = 0; }
        i = i + 1;
    }
    assert_eq(space_blank, 1, "cga space all-blank");

    # 'A' (0x41) = 0x386CC6C6FEC6C600 -> 38 6C C6 C6 FE C6 C6 00.
    assert_eq(kashi_glyph_row(KASHI_FONT_CGA_8X8, 0x41, 0), 0x38, "cga A row0");
    assert_eq(kashi_glyph_row(KASHI_FONT_CGA_8X8, 0x41, 1), 0x6C, "cga A row1");
    assert_eq(kashi_glyph_row(KASHI_FONT_CGA_8X8, 0x41, 4), 0xFE, "cga A row4");
    assert_eq(kashi_glyph_row(KASHI_FONT_CGA_8X8, 0x41, 7), 0x00, "cga A row7");

    # '1' (0x31) = 0x18381818181818FF -> last row 0xFF (long bottom bar).
    assert_eq(kashi_glyph_row(KASHI_FONT_CGA_8X8, 0x31, 0), 0x18, "cga 1 row0");
    assert_eq(kashi_glyph_row(KASHI_FONT_CGA_8X8, 0x31, 1), 0x38, "cga 1 row1");
    assert_eq(kashi_glyph_row(KASHI_FONT_CGA_8X8, 0x31, 7), 0xFF, "cga 1 row7");

    # '_' (0x5F) = 0x00000000000000FF -> only bottom row set.
    assert_eq(kashi_glyph_row(KASHI_FONT_CGA_8X8, 0x5F, 0), 0x00, "cga _ row0");
    assert_eq(kashi_glyph_row(KASHI_FONT_CGA_8X8, 0x5F, 7), 0xFF, "cga _ row7");

    # CGA high-half (0x80..0xFF) is intentionally blank in 0.4.0 — extending
    # the hand-drawn font would require 128 more glyphs (see ADR 0004).
    # Spot-check a couple of slots to lock the "blank" behavior so a future
    # change can't accidentally light them up.
    assert_eq(kashi_glyph_row(KASHI_FONT_CGA_8X8, 0x80, 0), 0, "cga 0x80 blank r0");
    assert_eq(kashi_glyph_row(KASHI_FONT_CGA_8X8, 0xDB, 4), 0, "cga 0xDB blank r4");
    assert_eq(kashi_glyph_row(KASHI_FONT_CGA_8X8, 0xFF, 7), 0, "cga 0xFF blank r7");
    # The slot exists (ptr non-null), it's just zeroed.
    assert_neq(kashi_glyph_ptr(KASHI_FONT_CGA_8X8, 0xC9), 0, "cga 0xC9 slot exists");
    return 0;
}

# --- font_data core: accessor bounds + ptr round-trip ---

fn test_accessor_bounds() {
    test_group("accessor bounds");
    assert_eq(kashi_glyph_row(KASHI_FONT_VGA_8X16, 0x1F, 0), 0, "row oob-char-lo 0");
    assert_eq(kashi_glyph_row(KASHI_FONT_VGA_8X16, 0x100, 0), 0, "row oob-char-hi 0");
    assert_eq(kashi_glyph_ptr(KASHI_FONT_VGA_8X16, 0x1F), 0, "ptr oob-char-lo null");
    assert_eq(kashi_glyph_ptr(KASHI_FONT_VGA_8X16, 0x100), 0, "ptr oob-char-hi null");

    assert_eq(kashi_glyph_row(7, 0x41, 0), 0, "row unknown-font 0");
    assert_eq(kashi_glyph_ptr(7, 0x41), 0, "ptr unknown-font null");

    assert_eq(kashi_glyph_row(KASHI_FONT_VGA_8X16, 0x41, 0 - 1), 0, "row neg 0");
    assert_eq(kashi_glyph_row(KASHI_FONT_VGA_8X16, 0x41, 16), 0, "row >=16 0");
    assert_eq(kashi_glyph_row(KASHI_FONT_CGA_8X8, 0x41, 8), 0, "row >=8 0");

    # ptr round-trip: glyph_row(ch,row) == load8(glyph_ptr(ch)+row).
    var p = kashi_glyph_ptr(KASHI_FONT_VGA_8X16, 0x41);
    assert_neq(p, 0, "A ptr non-null");
    assert_eq(load8(p + 5), kashi_glyph_row(KASHI_FONT_VGA_8X16, 0x41, 5), "ptr/row agree");
    assert_eq(load8(p + 7), 0xFE, "ptr row7 0xFE");

    # ptr spacing: consecutive glyphs are exactly height bytes apart.
    var pa = kashi_glyph_ptr(KASHI_FONT_VGA_8X16, 0x41);
    var pb = kashi_glyph_ptr(KASHI_FONT_VGA_8X16, 0x42);
    assert_eq(pb - pa, 16, "vga glyph stride 16");
    var qa = kashi_glyph_ptr(KASHI_FONT_CGA_8X8, 0x41);
    var qb = kashi_glyph_ptr(KASHI_FONT_CGA_8X8, 0x42);
    assert_eq(qb - qa, 8, "cga glyph stride 8");
    return 0;
}

# --- font_data core: every encoded glyph has a non-null ptr in range ---

fn test_full_coverage() {
    test_group("full coverage");
    var ch = 0x20;
    var all_ok16 = 1;
    var all_ok8 = 1;
    while (ch <= 0xFF) {
        if (kashi_glyph_ptr(KASHI_FONT_VGA_8X16, ch) == 0) { all_ok16 = 0; }
        if (kashi_glyph_ptr(KASHI_FONT_CGA_8X8, ch) == 0) { all_ok8 = 0; }
        ch = ch + 1;
    }
    assert_eq(all_ok16, 1, "all 224 vga glyphs present");
    assert_eq(all_ok8, 1, "all 224 cga glyph slots present (high-half blank)");
    return 0;
}

# --- library surface (src/lib.cyr): result codes + bad-arg rejection ---
# Runs before any runtime registration, so kashi_font_total is still 2.

fn test_lib_skeleton() {
    test_group("library surface");
    assert_eq(kashi_font_total(), 2, "two built-in fonts (pre-load)");
    assert_eq(KASHI_OK, 0, "ok is zero");
    # load/register reject bad args with a NEGATIVE error (0 - code).
    assert_eq(kashi_load_psf(0, 100), 0 - KASHI_EINVAL, "psf load null -> -einval");
    assert_eq(kashi_register_font(0, 16, &kashi_font16, 96), 0 - KASHI_EINVAL, "register bad-w -> -einval");
    return 0;
}

# --- audit 2026-05-27 hardening: ready flag, fset guard, full-range inputs ---

# F2: kashi_font_is_ready() reads back the (previously write-only) ready flag.
fn test_font_ready() {
    test_group("font ready flag");
    # main() already called kashi_font_init(), so the flag must read set.
    assert_eq(kashi_font_is_ready(), 1, "ready after init");
    return 0;
}

# F1: kashi_fset16/fset8 must IGNORE an out-of-range ch rather than writing at
# a negative/overrun offset. The suppressed write isn't directly observable,
# but a barrage of out-of-range packs must leave the in-range table intact.
fn test_fset_guard() {
    test_group("fset guard");
    var ones = 0xFFFFFFFFFFFFFFFF;
    # Below FIRST (0x20) and above LAST (0xFF), both fonts.
    kashi_fset16(0x1F, ones, ones);
    kashi_fset16(0x100, ones, ones);
    kashi_fset16(0 - 1, ones, ones);
    kashi_fset8(0x1F, ones);
    kashi_fset8(0x100, ones);
    kashi_fset8(0 - 1, ones);
    # In-range glyphs unchanged: space blank, 'A' row, DEL triangle base.
    assert_eq(kashi_glyph_row(KASHI_FONT_VGA_8X16, 0x20, 0), 0x00, "guard: vga space intact");
    assert_eq(kashi_glyph_row(KASHI_FONT_VGA_8X16, 0x41, 7), 0xFE, "guard: vga A intact");
    assert_eq(kashi_glyph_row(KASHI_FONT_VGA_8X16, 0x7F, 10), 0xFE, "guard: vga DEL intact");
    assert_eq(kashi_glyph_row(KASHI_FONT_CGA_8X8, 0x41, 4), 0xFE, "guard: cga A intact");
    assert_eq(kashi_font_is_ready(), 1, "guard: ready intact");
    # Restore a clean table for later tests (defensive if the guard regresses).
    kashi_font_init();
    return 0;
}

# F5: the accessors are bounds-safe for the FULL i64 range, not just the
# 0..255 byte range the fuzz harness reaches. Pin the extremes explicitly.
fn test_extreme_inputs() {
    test_group("extreme inputs");
    # Huge / negative font_id.
    assert_eq(kashi_glyph_row(0x7FFFFFFF, 0x41, 0), 0, "huge font -> 0");
    assert_eq(kashi_glyph_row(0 - 5, 0x41, 0), 0, "neg font -> 0");
    assert_eq(kashi_glyph_ptr(0x7FFFFFFF, 0x41), 0, "huge font ptr null");
    # Huge / negative ch.
    assert_eq(kashi_glyph_encoded(0x7FFFFFFF), 0, "huge ch unencoded");
    assert_eq(kashi_glyph_encoded(0 - 2000000000), 0, "big-neg ch unencoded");
    assert_eq(kashi_glyph_row(KASHI_FONT_VGA_8X16, 0x7FFFFFFF, 0), 0, "huge ch -> 0");
    assert_eq(kashi_glyph_ptr(KASHI_FONT_VGA_8X16, 0x7FFFFFFF), 0, "huge ch ptr null");
    # Huge / very-negative row.
    assert_eq(kashi_glyph_row(KASHI_FONT_VGA_8X16, 0x41, 0x7FFFFFFF), 0, "huge row -> 0");
    assert_eq(kashi_glyph_row(KASHI_FONT_VGA_8X16, 0x41, 0 - 1000), 0, "big-neg row -> 0");
    return 0;
}

# --- M1: PSF parser (src/font_psf.cyr) ---

# Write a 32-bit little-endian value into buf at off (no store32 dependency).
fn _put32(buf, off, v) {
    store8(buf + off + 0, v & 0xFF);
    store8(buf + off + 1, (v >> 8) & 0xFF);
    store8(buf + off + 2, (v >> 16) & 0xFF);
    store8(buf + off + 3, (v >> 24) & 0xFF);
    return 0;
}

# Lay down a PSF1 header in buf; return total byte length. count is 256, or
# 512 if mode bit 0 is set. Glyph data is left uninitialized (the parser
# validates length but never reads glyph bytes).
fn _mk_psf1(buf, mode, charsize) {
    store8(buf + 0, 0x36);
    store8(buf + 1, 0x04);
    store8(buf + 2, mode);
    store8(buf + 3, charsize);
    var count = 256;
    if ((mode & 1) != 0) { count = 512; }
    return 4 + count * charsize;
}

# Lay down a PSF2 header in buf (charsize forced to height = 1 byte/row);
# return total length. Glyph data left uninitialized.
fn _mk_psf2(buf, count, height, width, flags) {
    var i = 0;
    while (i < 32) { store8(buf + i, 0); i = i + 1; }
    _put32(buf, 0, 0x864AB572);   # magic
    _put32(buf, 4, 0);            # version
    _put32(buf, 8, 32);           # headersize
    _put32(buf, 12, flags);
    _put32(buf, 16, count);
    _put32(buf, 20, height);      # charsize = height
    _put32(buf, 24, height);
    _put32(buf, 28, width);
    return 32 + count * height;
}

# Lay down a PSF1 (256 glyphs, mode HASTAB) with a Unicode table that maps a
# single glyph index -> codepoint; all other glyphs get an empty entry.
# Glyph data is zeroed (caller plants what it needs). Returns total length.
fn _mk_psf1_tab(buf, charsize, map_glyph, map_cp) {
    store8(buf + 0, 0x36);
    store8(buf + 1, 0x04);
    store8(buf + 2, 0x02);   # mode bit 1 = HASTAB
    store8(buf + 3, charsize);
    var dataend = 4 + 256 * charsize;
    var i = 4;
    while (i < dataend) { store8(buf + i, 0); i = i + 1; }
    var pos = dataend;
    var g = 0;
    while (g < 256) {
        if (g == map_glyph) {
            store8(buf + pos + 0, map_cp & 0xFF);
            store8(buf + pos + 1, (map_cp >> 8) & 0xFF);
            pos = pos + 2;
        }
        store8(buf + pos + 0, 0xFF);   # 0xFFFF glyph terminator
        store8(buf + pos + 1, 0xFF);
        pos = pos + 2;
        g = g + 1;
    }
    return pos;
}

fn test_psf1_parse() {
    test_group("psf1 parse");
    var buf = alloc(4 + 256 * 8);
    var len = _mk_psf1(buf, 0, 8);   # mode 0 (256 glyphs), height 8
    var hdr[56];
    assert_eq(kashi_psf_parse(buf, len, &hdr), KASHI_OK, "psf1 ok");
    assert_eq(load64(&hdr + KASHI_PH_KIND), KASHI_PSF_KIND_PSF1, "psf1 kind");
    assert_eq(load64(&hdr + KASHI_PH_WIDTH), 8, "psf1 width 8");
    assert_eq(load64(&hdr + KASHI_PH_HEIGHT), 8, "psf1 height 8");
    assert_eq(load64(&hdr + KASHI_PH_COUNT), 256, "psf1 count 256");
    assert_eq(load64(&hdr + KASHI_PH_CHARSIZE), 8, "psf1 charsize 8");
    assert_eq(load64(&hdr + KASHI_PH_DATAOFF), 4, "psf1 dataoff 4");

    var buf2 = alloc(4 + 512 * 8);
    var len2 = _mk_psf1(buf2, 1, 8);   # mode bit0 = 512-glyph bank
    assert_eq(kashi_psf_parse(buf2, len2, &hdr), KASHI_OK, "psf1-512 ok");
    assert_eq(load64(&hdr + KASHI_PH_COUNT), 512, "psf1-512 count 512");
    return 0;
}

fn test_psf2_parse() {
    test_group("psf2 parse");
    var buf = alloc(32 + 2 * 16);
    var len = _mk_psf2(buf, 2, 16, 8, 0);   # 2 glyphs, 8x16
    var hdr[56];
    assert_eq(kashi_psf_parse(buf, len, &hdr), KASHI_OK, "psf2 ok");
    assert_eq(load64(&hdr + KASHI_PH_KIND), KASHI_PSF_KIND_PSF2, "psf2 kind");
    assert_eq(load64(&hdr + KASHI_PH_WIDTH), 8, "psf2 width 8");
    assert_eq(load64(&hdr + KASHI_PH_HEIGHT), 16, "psf2 height 16");
    assert_eq(load64(&hdr + KASHI_PH_COUNT), 2, "psf2 count 2");
    assert_eq(load64(&hdr + KASHI_PH_CHARSIZE), 16, "psf2 charsize 16");
    assert_eq(load64(&hdr + KASHI_PH_DATAOFF), 32, "psf2 dataoff 32");
    return 0;
}

# Validation-first: every malformed/unsupported/truncated input is rejected
# with a sentinel, never a wild read.
fn test_psf_errors() {
    test_group("psf parse errors");
    var hdr[56];
    assert_eq(kashi_psf_parse(0, 10, &hdr), KASHI_EINVAL, "null buf einval");
    var b = alloc(64);
    assert_eq(kashi_psf_parse(b, 0 - 1, &hdr), KASHI_EINVAL, "neg len einval");
    var i = 0;
    while (i < 64) { store8(b + i, 0); i = i + 1; }
    assert_eq(kashi_psf_parse(b, 64, &hdr), KASHI_EFORMAT, "bad magic eformat");

    # PSF1 magic but far too short for 256*8 glyph bytes.
    var t = alloc(64);
    store8(t + 0, 0x36); store8(t + 1, 0x04); store8(t + 2, 0); store8(t + 3, 8);
    assert_eq(kashi_psf_parse(t, 64, &hdr), KASHI_EFORMAT, "psf1 truncated eformat");

    # PSF2 width 9 (> 8) — unsupported in M1.
    var w = alloc(32 + 2 * 16);
    var wlen = _mk_psf2(w, 2, 16, 9, 0);
    assert_eq(kashi_psf_parse(w, wlen, &hdr), KASHI_EFORMAT, "psf2 wide eformat");

    # PSF2 version != 0.
    var v = alloc(32 + 2 * 16);
    var vlen = _mk_psf2(v, 2, 16, 8, 0);
    _put32(v, 4, 1);
    assert_eq(kashi_psf_parse(v, vlen, &hdr), KASHI_EFORMAT, "psf2 bad version eformat");

    # PSF2 charsize disagrees with height.
    var c = alloc(32 + 2 * 16);
    var clen = _mk_psf2(c, 2, 16, 8, 0);
    _put32(c, 20, 99);
    assert_eq(kashi_psf_parse(c, clen, &hdr), KASHI_EFORMAT, "psf2 bad charsize eformat");
    return 0;
}

# --- M1: runtime font registry + unified dispatch (src/lib.cyr) ---

fn test_rt_fonts() {
    test_group("runtime fonts");
    var before = kashi_font_total();

    # Register a tiny 8x4 font: glyph 0 rows = 1,2,3,4; glyph 1 = 0x80..0x10.
    var data = alloc(2 * 4);
    store8(data + 0, 1); store8(data + 1, 2); store8(data + 2, 3); store8(data + 3, 4);
    store8(data + 4, 0x80); store8(data + 5, 0x40); store8(data + 6, 0x20); store8(data + 7, 0x10);
    var id = kashi_register_font(8, 4, data, 2);
    assert_gte(id, KASHI_RT_FONT_BASE, "register returns id >= 2");
    assert_eq(kashi_font_total(), before + 1, "total grew by 1");
    assert_eq(kashi_rt_font_width(id), 8, "rt width 8");
    assert_eq(kashi_rt_font_height(id), 4, "rt height 4");
    assert_eq(kashi_rt_font_count(id), 2, "rt count 2");

    # Unified dispatcher reads runtime rows by glyph index.
    assert_eq(kashi_font_row(id, 0, 0), 1, "rt g0 r0");
    assert_eq(kashi_font_row(id, 0, 3), 4, "rt g0 r3");
    assert_eq(kashi_font_row(id, 1, 0), 0x80, "rt g1 r0");
    # Out-of-range glyph index / row -> 0; ptr -> null.
    assert_eq(kashi_font_row(id, 2, 0), 0, "rt oob glyph -> 0");
    assert_eq(kashi_font_row(id, 0, 4), 0, "rt oob row -> 0");
    assert_eq(kashi_font_ptr(id, 5), 0, "rt oob glyph ptr null");
    # register() owns a COPY — mutating the source must not change the font.
    store8(data + 0, 0xFF);
    assert_eq(kashi_font_row(id, 0, 0), 1, "rt font owns its copy");

    # Unified dispatcher routes built-in ids to the freestanding core.
    assert_eq(kashi_font_row(KASHI_FONT_VGA_8X16, 0x41, 7),
    kashi_glyph_row(KASHI_FONT_VGA_8X16, 0x41, 7), "dispatch builtin == core");
    assert_eq(kashi_font_row(KASHI_FONT_VGA_8X16, 0x41, 7), 0xFE, "dispatch builtin A row7");
    assert_eq(kashi_font_ptr(KASHI_FONT_CGA_8X8, 0x41),
    kashi_glyph_ptr(KASHI_FONT_CGA_8X8, 0x41), "dispatch builtin ptr == core");

    # Load a PSF1 (256 glyphs, height 2); plant glyph 0x41 rows = 0xAB,0xCD.
    var pbuf = alloc(4 + 256 * 2);
    var plen = _mk_psf1(pbuf, 0, 2);
    store8(pbuf + 4 + 0x41 * 2 + 0, 0xAB);
    store8(pbuf + 4 + 0x41 * 2 + 1, 0xCD);
    var pid = kashi_load_psf(pbuf, plen);
    assert_gte(pid, KASHI_RT_FONT_BASE, "psf load returns id >= 2");
    assert_eq(kashi_rt_font_count(pid), 256, "psf font count 256");
    assert_eq(kashi_font_row(pid, 0x41, 0), 0xAB, "psf glyph 0x41 r0");
    assert_eq(kashi_font_row(pid, 0x41, 1), 0xCD, "psf glyph 0x41 r1");
    # Malformed loads return a negative error.
    assert_eq(kashi_load_psf(0, 10), 0 - KASHI_EINVAL, "psf load null -> -einval");
    assert_lt(kashi_load_psf(pbuf, 3), 0, "psf load truncated -> negative");
    return 0;
}

# --- M2: Unicode table detection + token reader (src/font_psf.cyr) ---

fn test_psf_uni_token() {
    test_group("psf unicode token");
    var tok[24];

    # PSF1 table bytes (LE u16): [41 00][FF FE][FF FF] -> CP 0x41, SEQ, TERM.
    var p1 = alloc(6);
    store8(p1 + 0, 0x41); store8(p1 + 1, 0x00);
    store8(p1 + 2, 0xFE); store8(p1 + 3, 0xFF);
    store8(p1 + 4, 0xFF); store8(p1 + 5, 0xFF);
    kashi_psf_uni_token(p1, 0, 6, KASHI_PSF_KIND_PSF1, &tok);
    assert_eq(load64(&tok + KASHI_UT_TYPE), KASHI_TOK_CP, "psf1 tok cp");
    assert_eq(load64(&tok + KASHI_UT_CP), 0x41, "psf1 tok cp val");
    assert_eq(load64(&tok + KASHI_UT_NEXT), 2, "psf1 tok next");
    kashi_psf_uni_token(p1, 2, 6, KASHI_PSF_KIND_PSF1, &tok);
    assert_eq(load64(&tok + KASHI_UT_TYPE), KASHI_TOK_SEQ, "psf1 tok seq");
    kashi_psf_uni_token(p1, 4, 6, KASHI_PSF_KIND_PSF1, &tok);
    assert_eq(load64(&tok + KASHI_UT_TYPE), KASHI_TOK_TERM, "psf1 tok term");
    kashi_psf_uni_token(p1, 6, 6, KASHI_PSF_KIND_PSF1, &tok);
    assert_eq(load64(&tok + KASHI_UT_TYPE), KASHI_TOK_END, "psf1 tok end");
    kashi_psf_uni_token(p1, 5, 6, KASHI_PSF_KIND_PSF1, &tok);
    assert_eq(load64(&tok + KASHI_UT_TYPE), KASHI_TOK_END, "psf1 tok trunc end");

    # PSF2 table bytes (UTF-8): 41, C3 A9 (U+00E9), FF, FE, truncated C3.
    var p2 = alloc(7);
    store8(p2 + 0, 0x41);
    store8(p2 + 1, 0xC3); store8(p2 + 2, 0xA9);
    store8(p2 + 3, 0xFF);
    store8(p2 + 4, 0xFE);
    store8(p2 + 5, 0xC3); store8(p2 + 6, 0x00);
    kashi_psf_uni_token(p2, 0, 7, KASHI_PSF_KIND_PSF2, &tok);
    assert_eq(load64(&tok + KASHI_UT_TYPE), KASHI_TOK_CP, "psf2 ascii cp");
    assert_eq(load64(&tok + KASHI_UT_CP), 0x41, "psf2 ascii val");
    assert_eq(load64(&tok + KASHI_UT_NEXT), 1, "psf2 ascii next");
    kashi_psf_uni_token(p2, 1, 7, KASHI_PSF_KIND_PSF2, &tok);
    assert_eq(load64(&tok + KASHI_UT_TYPE), KASHI_TOK_CP, "psf2 2byte cp");
    assert_eq(load64(&tok + KASHI_UT_CP), 0xE9, "psf2 2byte val U+00E9");
    assert_eq(load64(&tok + KASHI_UT_NEXT), 3, "psf2 2byte next");
    kashi_psf_uni_token(p2, 3, 7, KASHI_PSF_KIND_PSF2, &tok);
    assert_eq(load64(&tok + KASHI_UT_TYPE), KASHI_TOK_TERM, "psf2 term");
    kashi_psf_uni_token(p2, 4, 7, KASHI_PSF_KIND_PSF2, &tok);
    assert_eq(load64(&tok + KASHI_UT_TYPE), KASHI_TOK_SEQ, "psf2 seq");
    kashi_psf_uni_token(p2, 5, 6, KASHI_PSF_KIND_PSF2, &tok);
    assert_eq(load64(&tok + KASHI_UT_TYPE), KASHI_TOK_END, "psf2 trunc end");

    # UNIOFF detection: PSF1 with HASTAB mode + a table appended vs. without.
    var hdr[56];
    var fc = 4 + 256 * 1;
    var fb = alloc(fc + 4);
    var k = 0;
    while (k < fc + 4) { store8(fb + k, 0); k = k + 1; }
    store8(fb + 0, 0x36); store8(fb + 1, 0x04); store8(fb + 2, 0x02); store8(fb + 3, 1);
    assert_eq(kashi_psf_parse(fb, fc + 4, &hdr), KASHI_OK, "psf1+tab parse ok");
    assert_eq(load64(&hdr + KASHI_PH_UNIOFF), fc, "psf1 unioff set");
    var nb = alloc(fc);
    var m = 0;
    while (m < fc) { store8(nb + m, 0); m = m + 1; }
    store8(nb + 0, 0x36); store8(nb + 1, 0x04); store8(nb + 2, 0x00); store8(nb + 3, 1);
    assert_eq(kashi_psf_parse(nb, fc, &hdr), KASHI_OK, "psf1 notab parse ok");
    assert_eq(load64(&hdr + KASHI_PH_UNIOFF), 0, "psf1 no unioff");
    return 0;
}

# --- M2: codepoint addressing via the PSF Unicode map (src/lib.cyr) ---

fn test_rt_unicode() {
    test_group("runtime unicode map");

    # PSF1 + Unicode table: map glyph 10 -> 'Z' (0x5A), charsize 2.
    var cs = 2;
    var p1 = alloc(4 + 256 * cs + 256 * 2 + 4);
    var len1 = _mk_psf1_tab(p1, cs, 10, 0x5A);
    store8(p1 + 4 + 10 * cs + 0, 0x5A);   # plant glyph 10 rows
    store8(p1 + 4 + 10 * cs + 1, 0xA5);
    var id1 = kashi_load_psf(p1, len1);
    assert_gte(id1, KASHI_RT_FONT_BASE, "psf1+tab load ok");
    assert_eq(kashi_font_row(id1, 0x5A, 0), 0x5A, "psf1 cp Z -> glyph10 r0");
    assert_eq(kashi_font_row(id1, 0x5A, 1), 0xA5, "psf1 cp Z -> glyph10 r1");
    assert_eq(kashi_rt_glyph_row(id1, 10, 0), 0x5A, "psf1 raw idx 10 agrees");
    assert_eq(kashi_font_row(id1, 0x41, 0), 0, "psf1 unmapped cp 'A' -> 0");
    assert_eq(kashi_font_ptr(id1, 0x42), 0, "psf1 unmapped cp 'B' ptr null");

    # PSF2 + Unicode table (UTF-8): 8 glyphs, height 2. glyph 3 -> 'A' (0x41),
    # glyph 5 -> U+00E9 (UTF-8 C3 A9).
    var p2 = alloc(128);
    var k = 0;
    while (k < 128) { store8(p2 + k, 0); k = k + 1; }
    _put32(p2, 0, 0x864AB572); _put32(p2, 4, 0); _put32(p2, 8, 32);
    _put32(p2, 12, 1);             # flags = HAS_UNICODE
    _put32(p2, 16, 8);             # count
    _put32(p2, 20, 2);             # charsize
    _put32(p2, 24, 2);             # height
    _put32(p2, 28, 8);             # width
    store8(p2 + 32 + 3 * 2 + 0, 0x11); store8(p2 + 32 + 3 * 2 + 1, 0x22);  # glyph 3
    store8(p2 + 32 + 5 * 2 + 0, 0x33); store8(p2 + 32 + 5 * 2 + 1, 0x44);  # glyph 5
    var tp = 48;                   # 32 + 8*2 = table start
    store8(p2 + tp, 0xFF); tp = tp + 1;   # g0
    store8(p2 + tp, 0xFF); tp = tp + 1;   # g1
    store8(p2 + tp, 0xFF); tp = tp + 1;   # g2
    store8(p2 + tp, 0x41); store8(p2 + tp + 1, 0xFF); tp = tp + 2;             # g3 -> 'A'
    store8(p2 + tp, 0xFF); tp = tp + 1;   # g4
    store8(p2 + tp, 0xC3); store8(p2 + tp + 1, 0xA9); store8(p2 + tp + 2, 0xFF); tp = tp + 3;  # g5 -> U+00E9
    store8(p2 + tp, 0xFF); tp = tp + 1;   # g6
    store8(p2 + tp, 0xFF); tp = tp + 1;   # g7
    var id2 = kashi_load_psf(p2, tp);
    assert_gte(id2, KASHI_RT_FONT_BASE, "psf2+tab load ok");
    assert_eq(kashi_rt_font_count(id2), 8, "psf2 count 8");
    assert_eq(kashi_font_row(id2, 0x41, 0), 0x11, "psf2 cp 'A' -> glyph3 r0");
    assert_eq(kashi_font_row(id2, 0x41, 1), 0x22, "psf2 cp 'A' -> glyph3 r1");
    assert_eq(kashi_font_row(id2, 0xE9, 0), 0x33, "psf2 cp U+00E9 -> glyph5 r0");
    assert_eq(kashi_font_row(id2, 0xE9, 1), 0x44, "psf2 cp U+00E9 -> glyph5 r1");
    assert_eq(kashi_rt_glyph_row(id2, 5, 1), 0x44, "psf2 raw idx 5 agrees");
    assert_eq(kashi_font_row(id2, 0x42, 0), 0, "psf2 unmapped cp 'B' -> 0");
    return 0;
}

# --- M2 registry nicety: active-font knob ---

fn test_active_font() {
    test_group("active font");
    # Default is 0 (VGA built-in) — established at module load, valid even
    # before any registration.
    assert_eq(kashi_active_font(), 0, "default active = 0");
    # Round-trip set/get for both built-ins.
    assert_eq(kashi_set_active_font(KASHI_FONT_CGA_8X8), KASHI_OK, "set to CGA ok");
    assert_eq(kashi_active_font(), KASHI_FONT_CGA_8X8, "active reads CGA");
    assert_eq(kashi_set_active_font(KASHI_FONT_VGA_8X16), KASHI_OK, "set back to VGA ok");
    assert_eq(kashi_active_font(), KASHI_FONT_VGA_8X16, "active reads VGA");
    # Out-of-range ids -> negative error; active unchanged.
    assert_eq(kashi_set_active_font(0 - 1), 0 - KASHI_EINVAL, "neg id -> -einval");
    assert_eq(kashi_set_active_font(kashi_font_total()), 0 - KASHI_EINVAL, "total id -> -einval");
    assert_eq(kashi_set_active_font(0x7FFFFFFF), 0 - KASHI_EINVAL, "huge id -> -einval");
    assert_eq(kashi_active_font(), KASHI_FONT_VGA_8X16, "active unchanged on reject");
    return 0;
}

fn main() {
    alloc_init();

    # kashi_font_init() must run before any glyph access (freestanding
    # consumers call it explicitly; a stdlib consumer does the same).
    kashi_font_init();

    test_metadata();
    test_encoded_gate();
    test_vga_8x16_bytes();
    test_cga_8x8_bytes();
    test_accessor_bounds();
    test_full_coverage();
    test_lib_skeleton();
    test_font_ready();
    test_fset_guard();
    test_extreme_inputs();
    test_psf1_parse();
    test_psf2_parse();
    test_psf_errors();
    test_psf_uni_token();
    test_rt_fonts();
    test_rt_unicode();
    test_active_font();

    return assert_summary();
}

var exit_code = main();
syscall(SYS_EXIT, exit_code);
