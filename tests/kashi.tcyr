# kashi — integration test suite (cross-module behavior).
# Stdlib auto-included via cyrius.cyml. The src/test.cyr entry holds the
# bulk of the unit assertions; this file exercises the public surface the
# way a consumer would: init once, then iterate the whole glyph range and
# check structural invariants that span the two fonts.

include "src/lib.cyr"

# Count set bits in one glyph row byte (population count over 8 bits).
fn popcount8(b) {
    var n = 0;
    var i = 0;
    while (i < 8) {
        if ((b & (1 << i)) != 0) { n = n + 1; }
        i = i + 1;
    }
    return n;
}

# Total set pixels across a whole glyph (sum of popcounts over its rows).
fn glyph_ink(font_id, ch) {
    var h = kashi_font_height(font_id);
    var total = 0;
    var row = 0;
    while (row < h) {
        total = total + popcount8(kashi_glyph_row(font_id, ch, row));
        row = row + 1;
    }
    return total;
}

# Invariant: a font's render width is 8, so no glyph row can have a set bit
# outside the low 8 bits. (kashi_glyph_row returns a single byte, but verify
# the value really is byte-bounded.)
fn test_row_byte_bounded() {
    test_group("row byte-bounded");
    var ch = 0x20;
    var ok = 1;
    while (ch <= 0xFF) {
        var row = 0;
        while (row < 16) {
            if (kashi_glyph_row(KASHI_FONT_VGA_8X16, ch, row) > 0xFF) { ok = 0; }
            row = row + 1;
        }
        ch = ch + 1;
    }
    assert_eq(ok, 1, "all vga rows <= 0xFF");
    return 0;
}

# Invariant: SPACE (0x20) is blank ink in BOTH fonts; a visible glyph like
# 'M' (0x4D) has ink in both. This catches a whole-table off-by-one in the
# (ch - first) index math (which would shift every glyph by one slot).
fn test_space_vs_visible() {
    test_group("space vs visible");
    assert_eq(glyph_ink(KASHI_FONT_VGA_8X16, 0x20), 0, "vga space no ink");
    assert_eq(glyph_ink(KASHI_FONT_CGA_8X8, 0x20), 0, "cga space no ink");
    assert_gt(glyph_ink(KASHI_FONT_VGA_8X16, 0x4D), 0, "vga M has ink");
    assert_gt(glyph_ink(KASHI_FONT_CGA_8X8, 0x4D), 0, "cga M has ink");
    # 'M' is a dense glyph; both fonts should carry substantial ink.
    assert_gt(glyph_ink(KASHI_FONT_VGA_8X16, 0x4D), 20, "vga M dense");
    assert_gt(glyph_ink(KASHI_FONT_CGA_8X8, 0x4D), 15, "cga M dense");
    return 0;
}

# Invariant: the index math is monotone — glyph N's pointer is exactly one
# glyph-height past glyph N-1's, across the full range, for both fonts.
fn test_pointer_monotone() {
    test_group("pointer monotone");
    var ok16 = 1;
    var ok8 = 1;
    var ch = 0x21;
    while (ch <= 0xFF) {
        var prev16 = kashi_glyph_ptr(KASHI_FONT_VGA_8X16, ch - 1);
        var cur16 = kashi_glyph_ptr(KASHI_FONT_VGA_8X16, ch);
        if (cur16 - prev16 != 16) { ok16 = 0; }
        var prev8 = kashi_glyph_ptr(KASHI_FONT_CGA_8X8, ch - 1);
        var cur8 = kashi_glyph_ptr(KASHI_FONT_CGA_8X8, ch);
        if (cur8 - prev8 != 8) { ok8 = 0; }
        ch = ch + 1;
    }
    assert_eq(ok16, 1, "vga ptrs 16 apart");
    assert_eq(ok8, 1, "cga ptrs 8 apart");
    return 0;
}

# Re-init idempotency: calling kashi_font_init twice yields identical bytes.
fn test_reinit_idempotent() {
    test_group("reinit idempotent");
    var before = kashi_glyph_row(KASHI_FONT_VGA_8X16, 0x40, 7);
    kashi_font_init();
    var after = kashi_glyph_row(KASHI_FONT_VGA_8X16, 0x40, 7);
    assert_eq(before, after, "reinit stable");
    return 0;
}

# End-to-end PSF import: build a real PSF1 font, write it to a file, load it
# back via kashi_load_psf_file, and read glyph rows through the unified
# dispatcher — the way a userland consumer would. Exercises the parser,
# the io.file_read_all path, the glyph-store copy, and the registry.
fn test_psf_file_roundtrip() {
    test_group("psf file round-trip");
    # 256 glyphs, height 3. Plant glyph 'B' (index 0x42) rows = 0x11,0x22,0x33.
    var n = 4 + 256 * 3;
    var buf = alloc(n);
    var i = 0;
    while (i < n) { store8(buf + i, 0); i = i + 1; }
    store8(buf + 0, 0x36); store8(buf + 1, 0x04); store8(buf + 2, 0); store8(buf + 3, 3);
    store8(buf + 4 + 0x42 * 3 + 0, 0x11);
    store8(buf + 4 + 0x42 * 3 + 1, 0x22);
    store8(buf + 4 + 0x42 * 3 + 2, 0x33);

    var path = "/tmp/kashi_test_roundtrip.psf";
    file_write_all(path, buf, n);

    var id = kashi_load_psf_file(path);
    assert_gte(id, KASHI_RT_FONT_BASE, "file load returns id >= 2");
    assert_eq(kashi_rt_font_width(id), 8, "file font width 8");
    assert_eq(kashi_rt_font_height(id), 3, "file font height 3");
    assert_eq(kashi_rt_font_count(id), 256, "file font count 256");
    assert_eq(kashi_font_row(id, 0x42, 0), 0x11, "file glyph 0x42 r0");
    assert_eq(kashi_font_row(id, 0x42, 1), 0x22, "file glyph 0x42 r1");
    assert_eq(kashi_font_row(id, 0x42, 2), 0x33, "file glyph 0x42 r2");
    # A missing file is a negative error, not a crash.
    assert_lt(kashi_load_psf_file("/tmp/kashi_no_such_font_zzq.psf"), 0, "missing file -> negative");

    syscall(SYS_UNLINK, path);
    return 0;
}

# End-to-end codepoint addressing: write a PSF2 carrying a Unicode table,
# load it from a file, and fetch a glyph BY CODEPOINT through the unified
# dispatcher (the M2 path). All header fields here fit in one byte and the
# buffer is zeroed, so we store them directly (little-endian low byte).
fn test_psf_unicode_file() {
    test_group("psf unicode file round-trip");
    var buf = alloc(128);
    var i = 0;
    while (i < 128) { store8(buf + i, 0); i = i + 1; }
    # PSF2 header: 4 glyphs, height 3, width 8, flags = HAS_UNICODE.
    store8(buf + 0, 0x72); store8(buf + 1, 0xB5); store8(buf + 2, 0x4A); store8(buf + 3, 0x86);
    store8(buf + 8, 32);     # headersize
    store8(buf + 12, 1);     # flags: HAS_UNICODE
    store8(buf + 16, 4);     # count
    store8(buf + 20, 3);     # charsize
    store8(buf + 24, 3);     # height
    store8(buf + 28, 8);     # width
    # glyph 2 data (rows) at 32 + 2*3 = 38.
    store8(buf + 38, 0x71); store8(buf + 39, 0x72); store8(buf + 40, 0x73);
    # Unicode table at 32 + 4*3 = 44: g0 FF, g1 FF, g2 'Q'(0x51) FF, g3 FF.
    store8(buf + 44, 0xFF);
    store8(buf + 45, 0xFF);
    store8(buf + 46, 0x51); store8(buf + 47, 0xFF);
    store8(buf + 48, 0xFF);
    var len = 49;

    var path = "/tmp/kashi_test_unicode.psf";
    file_write_all(path, buf, len);
    var id = kashi_load_psf_file(path);
    assert_gte(id, KASHI_RT_FONT_BASE, "unicode file load ok");
    assert_eq(kashi_rt_font_count(id), 4, "unicode font count 4");
    # 'Q' resolves through the Unicode map to glyph 2.
    assert_eq(kashi_font_row(id, 0x51, 0), 0x71, "cp 'Q' -> glyph2 r0");
    assert_eq(kashi_font_row(id, 0x51, 2), 0x73, "cp 'Q' -> glyph2 r2");
    assert_eq(kashi_rt_glyph_row(id, 2, 0), 0x71, "raw idx 2 agrees");
    assert_eq(kashi_font_row(id, 0x41, 0), 0, "unmapped cp 'A' -> 0");

    syscall(SYS_UNLINK, path);
    return 0;
}

# BDF file round-trip: build a small BDF source, write it to a file, load it
# back via kashi_load_bdf_file, and read glyphs through the unified
# codepoint-addressed dispatcher. Exercises kashi_bdf_parse_header,
# kashi_bdf_next_glyph, the io.file_read_all path, and the cp-map build.
fn test_bdf_file_roundtrip() {
    test_group("bdf file round-trip");
    var buf = alloc(2048);
    var p = 0;
    p = _ti_str(buf, p, "STARTFONT 2.1\n");
    p = _ti_str(buf, p, "FONTBOUNDINGBOX 8 8 0 0\n");
    p = _ti_str(buf, p, "CHARS 2\n");
    p = _ti_str(buf, p, "STARTCHAR Q\n");
    p = _ti_str(buf, p, "ENCODING 81\n");
    p = _ti_str(buf, p, "BBX 8 8 0 0\n");
    p = _ti_str(buf, p, "BITMAP\nAA\nBB\nCC\nDD\nEE\nFF\n11\n22\nENDCHAR\n");
    p = _ti_str(buf, p, "STARTCHAR R\n");
    p = _ti_str(buf, p, "ENCODING 82\n");
    p = _ti_str(buf, p, "BBX 8 8 0 0\n");
    p = _ti_str(buf, p, "BITMAP\n01\n02\n03\n04\n05\n06\n07\n08\nENDCHAR\n");
    p = _ti_str(buf, p, "ENDFONT\n");

    var path = "/tmp/kashi_test_bdf.bdf";
    file_write_all(path, buf, p);
    var id = kashi_load_bdf_file(path);
    assert_gte(id, KASHI_RT_FONT_BASE, "bdf file load id >= rt base");
    assert_eq(kashi_rt_font_width(id), 8, "bdf file width 8");
    assert_eq(kashi_rt_font_height(id), 8, "bdf file height 8");
    assert_eq(kashi_rt_font_count(id), 2, "bdf file count 2");
    # 'Q' (0x51) rows.
    assert_eq(kashi_font_row(id, 0x51, 0), 0xAA, "bdf 'Q' r0");
    assert_eq(kashi_font_row(id, 0x51, 5), 0xFF, "bdf 'Q' r5");
    assert_eq(kashi_font_row(id, 0x51, 7), 0x22, "bdf 'Q' r7");
    # 'R' (0x52) rows.
    assert_eq(kashi_font_row(id, 0x52, 0), 0x01, "bdf 'R' r0");
    assert_eq(kashi_font_row(id, 0x52, 7), 0x08, "bdf 'R' r7");
    # Missing file -> negative.
    assert_lt(kashi_load_bdf_file("/tmp/kashi_no_such_bdf_zzq.bdf"), 0, "missing bdf negative");

    syscall(SYS_UNLINK, path);
    return 0;
}

# Tiny inline string-copy helper (mirrors src/test.cyr's _bdf_str).
fn _ti_str(buf, p, s) {
    var i = 0;
    var done = 0;
    while (done == 0) {
        var c = load8(s + i);
        if (c == 0) { done = 1; }
        if (done == 0) {
            store8(buf + p + i, c);
            i = i + 1;
        }
    }
    return p + i;
}

# PCF file round-trip: build a small PCF, write it to /tmp, load it
# back via kashi_load_pcf_file, verify glyph round-trip by codepoint.
# Exercises kashi_pcf_parse_header, decode_glyph (incl. bit-reverse
# branch), cp_to_idx, and the io.file_read_all path.
fn test_pcf_file_roundtrip() {
    test_group("pcf file round-trip");
    var buf = alloc(512);
    var p = 0;
    # Header
    store8(buf + 0, 0x01); store8(buf + 1, 0x66);
    store8(buf + 2, 0x63); store8(buf + 3, 0x70);
    _ti_put32(buf, 4, 3);
    # TOC: METRICS, BITMAPS, BDF_ENCODINGS — same layout as src/test.cyr's
    # _mk_pcf (compressed metrics, MSB-bit, LE-byte, scan/pad 1).
    var moff = 56;
    var msize = 4 + 2 + 2 * 5;
    _ti_put32(buf, 8, 0x04);
    _ti_put32(buf, 12, 0x108);
    _ti_put32(buf, 16, msize);
    _ti_put32(buf, 20, moff);
    var boff = moff + msize;
    var bsize = 4 + 4 + 2 * 4 + 16 + 2 * 8;
    _ti_put32(buf, 24, 0x08);
    _ti_put32(buf, 28, 0x08);
    _ti_put32(buf, 32, bsize);
    _ti_put32(buf, 36, boff);
    var eoff = boff + bsize;
    var esize = 4 + 5 * 2 + 2 * 2;
    _ti_put32(buf, 40, 0x20);
    _ti_put32(buf, 44, 0x08);
    _ti_put32(buf, 48, esize);
    _ti_put32(buf, 52, eoff);
    # METRICS body
    _ti_put32(buf, moff, 0x108);
    store8(buf + moff + 4, 2); store8(buf + moff + 5, 0);    # count = 2
    # Per-glyph: left=0, right=8, width=8, ascent=8, descent=0
    var mi = 0;
    while (mi < 2) {
        var s = moff + 6 + mi * 5;
        store8(buf + s + 0, 0x80);
        store8(buf + s + 1, 0x88);
        store8(buf + s + 2, 0x88);
        store8(buf + s + 3, 0x88);
        store8(buf + s + 4, 0x80);
        mi = mi + 1;
    }
    # BITMAPS body
    _ti_put32(buf, boff, 0x08);
    _ti_put32(buf, boff + 4, 2);
    _ti_put32(buf, boff + 8, 0);
    _ti_put32(buf, boff + 12, 8);
    _ti_put32(buf, boff + 16, 16);
    _ti_put32(buf, boff + 20, 48);
    _ti_put32(buf, boff + 24, 96);
    _ti_put32(buf, boff + 28, 192);
    var bd = boff + 32;
    # Glyph 0: Q-ish pattern
    store8(buf + bd + 0, 0x3C);
    store8(buf + bd + 1, 0x42);
    store8(buf + bd + 2, 0x42);
    store8(buf + bd + 3, 0x42);
    store8(buf + bd + 4, 0x42);
    store8(buf + bd + 5, 0x4A);
    store8(buf + bd + 6, 0x3C);
    store8(buf + bd + 7, 0x02);
    # Glyph 1: R-ish pattern
    store8(buf + bd + 8, 0x7C);
    store8(buf + bd + 9, 0x42);
    store8(buf + bd + 10, 0x42);
    store8(buf + bd + 11, 0x7C);
    store8(buf + bd + 12, 0x44);
    store8(buf + bd + 13, 0x42);
    store8(buf + bd + 14, 0x42);
    store8(buf + bd + 15, 0x00);
    # ENCODINGS body
    _ti_put32(buf, eoff, 0x08);
    store8(buf + eoff + 4, 0x51); store8(buf + eoff + 5, 0);   # min_b2 = 'Q'
    store8(buf + eoff + 6, 0x52); store8(buf + eoff + 7, 0);   # max_b2 = 'R'
    store8(buf + eoff + 8, 0); store8(buf + eoff + 9, 0);      # min_b1
    store8(buf + eoff + 10, 0); store8(buf + eoff + 11, 0);    # max_b1
    store8(buf + eoff + 12, 0); store8(buf + eoff + 13, 0);    # default
    store8(buf + eoff + 14, 0); store8(buf + eoff + 15, 0);    # 'Q' -> glyph 0
    store8(buf + eoff + 16, 1); store8(buf + eoff + 17, 0);    # 'R' -> glyph 1
    var total = eoff + esize;

    var path = "/tmp/kashi_test_pcf.pcf";
    file_write_all(path, buf, total);
    var id = kashi_load_pcf_file(path);
    assert_gte(id, KASHI_RT_FONT_BASE, "pcf file load id");
    assert_eq(kashi_rt_font_width(id), 8, "pcf file width");
    assert_eq(kashi_rt_font_height(id), 8, "pcf file height");
    assert_eq(kashi_rt_font_count(id), 2, "pcf file count");
    assert_eq(kashi_font_row(id, 0x51, 0), 0x3C, "pcf 'Q' r0");
    assert_eq(kashi_font_row(id, 0x51, 7), 0x02, "pcf 'Q' r7");
    assert_eq(kashi_font_row(id, 0x52, 0), 0x7C, "pcf 'R' r0");
    assert_eq(kashi_font_row(id, 0x52, 4), 0x44, "pcf 'R' r4");
    # Missing file -> negative.
    assert_lt(kashi_load_pcf_file("/tmp/kashi_no_such_pcf_zzq.pcf"), 0, "missing pcf negative");

    syscall(SYS_UNLINK, path);
    return 0;
}

# Tiny LE u32 helper (mirrors src/test.cyr's _put32).
fn _ti_put32(buf, off, v) {
    store8(buf + off + 0, v & 0xFF);
    store8(buf + off + 1, (v >> 8) & 0xFF);
    store8(buf + off + 2, (v >> 16) & 0xFF);
    store8(buf + off + 3, (v >> 24) & 0xFF);
    return 0;
}

fn main() {
    alloc_init();
    kashi_font_init();

    test_row_byte_bounded();
    test_space_vs_visible();
    test_pointer_monotone();
    test_reinit_idempotent();
    test_psf_file_roundtrip();
    test_psf_unicode_file();
    test_bdf_file_roundtrip();
    test_pcf_file_roundtrip();

    return assert_summary();
}

var exit_code = main();
syscall(SYS_EXIT, exit_code);
