# kashi benchmarks.
# Stdlib auto-included via cyrius.cyml.
#
# Pattern: bench_new -> bench_batch_start -> tight loop -> bench_batch_stop
# -> bench_report. For sub-1us ops use batch_size >= 1000 to amortize
# clock_gettime overhead. See lib/bench.cyr header for the full guidance.
#
# The font core is the hot path for any console: kashi_glyph_row is called
# once per pixel-row per glyph during text render. These benches measure
# the accessor cost (it should be a couple of branches plus a load8).

include "src/lib.cyr"

# Sum every row of every glyph in a font — the work a full-screen repaint
# approximates. Returns the accumulator so the optimizer can't elide it.
fn scan_font(font_id) {
    var acc = 0;
    var ch = 0x20;
    while (ch <= 0x7F) {
        var row = 0;
        var h = kashi_font_height(font_id);
        while (row < h) {
            acc = acc + kashi_glyph_row(font_id, ch, row);
            row = row + 1;
        }
        ch = ch + 1;
    }
    return acc;
}

fn main(): i64 {
    alloc_init();
    kashi_font_init();

    # Single-row accessor latency.
    var b1 = bench_new("glyph_row");
    bench_batch_start(b1);
    var i = 0;
    var sink = 0;
    while (i < 1000000) {
        sink = sink + kashi_glyph_row(KASHI_FONT_VGA_8X16, 0x41, 5);
        i = i + 1;
    }
    bench_batch_stop(b1, 1000000);
    bench_report(b1);

    # Pointer fetch latency.
    var b2 = bench_new("glyph_ptr");
    bench_batch_start(b2);
    i = 0;
    while (i < 1000000) {
        sink = sink + kashi_glyph_ptr(KASHI_FONT_VGA_8X16, 0x41);
        i = i + 1;
    }
    bench_batch_stop(b2, 1000000);
    bench_report(b2);

    # Whole-font scan (96 glyphs x 16 rows) — a full-screen-repaint proxy.
    var b3 = bench_new("scan_vga_8x16");
    bench_batch_start(b3);
    i = 0;
    while (i < 10000) {
        sink = sink + scan_font(KASHI_FONT_VGA_8X16);
        i = i + 1;
    }
    bench_batch_stop(b3, 10000);
    bench_report(b3);

    # Unified-dispatcher overhead vs the direct core accessor (b1): routing a
    # built-in id (0,1) through kashi_font_row adds one compare + branch.
    var b4 = bench_new("font_row_builtin");
    bench_batch_start(b4);
    i = 0;
    while (i < 1000000) {
        sink = sink + kashi_font_row(KASHI_FONT_VGA_8X16, 0x41, 5);
        i = i + 1;
    }
    bench_batch_stop(b4, 1000000);
    bench_report(b4);

    # Runtime-font path: register a small font, then time a glyph-index row
    # fetch (registry lookup + bounds + load8).
    var rt = kashi_register_font(8, 8, &kashi_font8, 8);
    var b5 = bench_new("font_row_runtime");
    bench_batch_start(b5);
    i = 0;
    while (i < 1000000) {
        sink = sink + kashi_font_row(rt, 0, 5);
        i = i + 1;
    }
    bench_batch_stop(b5, 1000000);
    bench_report(b5);

    return 0;
}

var r = main();
syscall(60, r);
