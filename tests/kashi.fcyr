# kashi fuzz harness.
# Stdlib auto-included via cyrius.cyml.
#
# The font accessors take arbitrary (font_id, ch, row) integers from the
# consumer. They must NEVER wild-deref or return out-of-buffer data for any
# input — a freestanding kernel renders whatever the accessor hands back.
# Fuzz the full int range of each argument and assert the bounds contract:
#   - out-of-range char/font/row => row 0, ptr 0 (null)
#   - in-range inputs => ptr inside the buffer, row == load8(ptr+row)

include "src/lib.cyr"

# Treat `data`/`len` as a stream of bytes that pick (font, ch, row).
fn fuzz_main(data, len) {
    if (len < 3) { return 0; }
    var font = load8(data + 0);
    var ch = load8(data + 1);
    var row = load8(data + 2);

    var r = kashi_glyph_row(font, ch, row);
    var p = kashi_glyph_ptr(font, ch);

    # Contract 1: a single row is always a byte (0..255). load8 guarantees
    # this, but assert so a future refactor that widens it gets caught.
    if (r < 0) { return 1; }
    if (r > 0xFF) { return 1; }

    # Contract 2: out-of-range inputs must yield the safe sentinels.
    var encoded = kashi_glyph_encoded(ch);
    var known_font = 0;
    if (font == KASHI_FONT_VGA_8X16) { known_font = 1; }
    if (font == KASHI_FONT_CGA_8X8) { known_font = 1; }

    if (encoded == 0) {
        if (r != 0) { return 1; }
        if (p != 0) { return 1; }
    }
    if (known_font == 0) {
        if (r != 0) { return 1; }
        if (p != 0) { return 1; }
    }

    # Contract 3: when both font and char are valid and the ptr is non-null,
    # a row within height must equal load8(ptr+row).
    if (encoded == 1) {
        if (known_font == 1) {
            if (p != 0) {
                var h = kashi_font_height(font);
                if (row >= 0) {
                    if (row < h) {
                        if (r != load8(p + row)) { return 1; }
                    }
                }
            }
        }
    }
    return 0;
}

# --- PSF parser fuzz (the untrusted-input surface) ---
#
# A malformed, truncated, or hostile PSF buffer must NEVER wild-deref:
# kashi_psf_parse must always return KASHI_OK / KASHI_EINVAL / KASHI_EFORMAT,
# kashi_load_psf must always return a value, and any font it *accepts* must
# yield in-bounds glyph rows for every (glyph index, row) — including the
# out-of-range ones, which must come back 0 / null.

var _rng = 0;
fn rng_seed(s) { _rng = s; return 0; }

# Cheap LCG returning a non-negative 31-bit value (avoids needing xor/shl).
fn rng_next() {
    _rng = _rng * 2862933555777941757 + 3037000493;
    return (_rng >> 16) & 0x7FFFFFFF;
}

fn fuzz_psf(rounds) {
    var cap = 2048;
    var buf = alloc(cap);
    var hdr[56];
    var r = 0;
    while (r < rounds) {
        var len = rng_next() % (cap + 1);
        var i = 0;
        while (i < len) {
            store8(buf + i, rng_next() & 0xFF);
            i = i + 1;
        }
        # Sometimes stamp a real magic so the fuzzer drives past detection
        # into the field-validation / length-bound logic; force the table
        # flag so accepted fonts exercise the Unicode map build on garbage.
        var pick = rng_next() & 3;
        if (pick == 0) {
            if (len >= 4) {
                store8(buf + 0, 0x36); store8(buf + 1, 0x04);
                store8(buf + 2, load8(buf + 2) | 0x02);     # PSF1 HASTAB
            }
        }
        if (pick == 1) {
            if (len >= 32) {
                store8(buf + 0, 0x72); store8(buf + 1, 0xB5);
                store8(buf + 2, 0x4A); store8(buf + 3, 0x86);
                store8(buf + 12, load8(buf + 12) | 0x01);   # PSF2 HAS_UNICODE
            }
        }

        # Contract 1: the parser only ever returns a known code, never crashes.
        var rc = kashi_psf_parse(buf, len, &hdr);
        if (rc != KASHI_OK) {
            if (rc != KASHI_EINVAL) {
                if (rc != KASHI_EFORMAT) { return 1; }
            }
        }

        # Contract 2: a full load (incl. map build from a garbage Unicode
        # table) returns a value; an accepted font is bounds-safe for every
        # probe.
        var id = kashi_load_psf(buf, len);
        if (id >= KASHI_RT_FONT_BASE) {
            var count = kashi_rt_font_count(id);
            var height = kashi_rt_font_height(id);
            var g = 0;
            while (g < 4) {
                var row = rng_next() & 0xFF;
                # Raw glyph-INDEX access: out-of-range index -> 0 / null.
                var idx = rng_next() % (count + 2);
                var rv = kashi_rt_glyph_row(id, idx, row);
                if (rv < 0) { return 2; }
                if (rv > 0xFF) { return 3; }
                if (idx >= count) {
                    if (rv != 0) { return 4; }
                    if (kashi_rt_glyph_ptr(id, idx) != 0) { return 5; }
                }
                if (row >= height) {
                    if (rv != 0) { return 6; }
                }
                # CODEPOINT access (map is arbitrary): only the byte-range /
                # no-crash contract holds.
                var cp = rng_next() & 0xFFFFF;
                var cv = kashi_font_row(id, cp, row);
                if (cv < 0) { return 7; }
                if (cv > 0xFF) { return 8; }
                # 0.5.0: multi-byte row accessor with random byte_idx
                # (covers stride > 1 fonts the parser now accepts).
                var bi = rng_next() & 7;
                var bv = kashi_font_row_byte(id, cp, row, bi);
                if (bv < 0) { return 9; }
                if (bv > 0xFF) { return 10; }
                # Also exercise the raw-index byte accessor.
                var rbv = kashi_rt_glyph_row_byte(id, idx, row, bi);
                if (rbv < 0) { return 11; }
                if (rbv > 0xFF) { return 12; }
                g = g + 1;
            }
            # 0.5.0: ligature lookup contract — never crashes; returns
            # either a non-negative glyph index or `0 - 1`.
            var probe[16];
            store64(&probe + 0, rng_next() & 0xFFFFF);
            store64(&probe + 8, rng_next() & 0xFFFFF);
            var sg = kashi_font_seq_glyph(id, &probe, 2);
            if (sg < 0 - 1) { return 13; }   # only sentinel is 0 - 1
            if (sg >= count) {
                if (sg != 0 - 1) { return 14; }   # any non-sentinel must be in range
            }
        }
        r = r + 1;
    }
    return 0;
}

# --- BDF parser fuzz (0.7.0) ---
#
# A malformed, truncated, or hostile BDF buffer must NEVER wild-deref. The
# BDF parser is text-based with more state than PSF (line scanning,
# whitespace, signed/hex int parsing, keyword dispatch), so it has more
# places to go wrong than PSF and warrants its own fuzz harness.

# Inline string-copy helper (mirrors src/test.cyr's _bdf_str).
fn _fz_str(buf, p, s) {
    var i = 0;
    var done = 0;
    while (done == 0) {
        var c = load8(s + i);
        if (c == 0) { done = 1; }
        if (done == 0) {
            store8(buf + p + i, c);
            i = i + 1;
        }
    }
    return p + i;
}

# Build a small valid 8x8 BDF template (2 glyphs) into buf; return length.
# Used by fuzz_bdf for the mutated-template path.
fn _fz_bdf_template(buf) {
    var p = 0;
    p = _fz_str(buf, p, "STARTFONT 2.1\n");
    p = _fz_str(buf, p, "FONTBOUNDINGBOX 8 8 0 0\n");
    p = _fz_str(buf, p, "CHARS 2\n");
    p = _fz_str(buf, p, "STARTCHAR A\n");
    p = _fz_str(buf, p, "ENCODING 65\n");
    p = _fz_str(buf, p, "BBX 8 8 0 0\n");
    p = _fz_str(buf, p, "BITMAP\n18\n24\n42\n7E\n42\n42\n42\n00\nENDCHAR\n");
    p = _fz_str(buf, p, "STARTCHAR B\n");
    p = _fz_str(buf, p, "ENCODING 66\n");
    p = _fz_str(buf, p, "BBX 8 8 0 0\n");
    p = _fz_str(buf, p, "BITMAP\n7C\n42\n42\n7C\n42\n42\n7C\n00\nENDCHAR\n");
    p = _fz_str(buf, p, "ENDFONT\n");
    return p;
}

fn fuzz_bdf(rounds) {
    var cap = 2048;
    var buf = alloc(cap);
    var hdr[56];
    var ctx[32];
    var gout[24];
    var dest[128];           # max charsize (32 * 4)
    var r = 0;
    while (r < rounds) {
        var pick = rng_next() & 3;
        var len = 0;
        if (pick == 0) {
            # Pure random bytes.
            len = rng_next() % (cap + 1);
            var i = 0;
            while (i < len) {
                store8(buf + i, rng_next() & 0xFF);
                i = i + 1;
            }
        }
        if (pick == 1) {
            # Valid template, no mutations.
            len = _fz_bdf_template(buf);
        }
        if (pick == 2) {
            # Valid template with a handful of random byte mutations.
            len = _fz_bdf_template(buf);
            var muts = (rng_next() & 7) + 1;
            var m = 0;
            while (m < muts) {
                var off = rng_next() % len;
                store8(buf + off, rng_next() & 0xFF);
                m = m + 1;
            }
        }
        if (pick == 3) {
            # Valid template, then truncated.
            len = _fz_bdf_template(buf);
            len = rng_next() % (len + 1);
        }

        # Contract 1: parse_header only returns a known code, never crashes.
        var rc = kashi_bdf_parse_header(buf, len, &hdr, &ctx);
        if (rc != KASHI_BDF_OK) {
            if (rc != KASHI_BDF_EINVAL) {
                if (rc != KASHI_BDF_EFORMAT) { return 1; }
            }
        }

        # Contract 2: next_glyph with random pos/end never crashes; returns
        # a known code; bounds-safe in its outputs.
        if (rc == KASHI_BDF_OK) {
            var pos = rng_next() % (len + 1);
            var grc = kashi_bdf_next_glyph(buf, pos, len, &ctx, &dest, 128, &gout);
            if (grc != KASHI_BDF_OK) {
                if (grc != KASHI_BDF_EINVAL) {
                    if (grc != KASHI_BDF_EFORMAT) { return 2; }
                }
            }
            if (grc == KASHI_BDF_OK) {
                var kind = load64(&gout + BG_KIND);
                if (kind < 0) { return 3; }
                if (kind > BG_KIND_END) { return 4; }
                var nxt = load64(&gout + BG_NEXT);
                if (nxt < 0) { return 5; }
                if (nxt > len) { return 6; }
            }
        }

        # Contract 3: full load returns a value; any accepted font is
        # bounds-safe under random probes (same posture as fuzz_psf).
        var id = kashi_load_bdf(buf, len);
        if (id >= KASHI_RT_FONT_BASE) {
            var count = kashi_rt_font_count(id);
            var height = kashi_rt_font_height(id);
            var g = 0;
            while (g < 3) {
                var row = rng_next() & 0xFF;
                var idx = rng_next() % (count + 2);
                var rv = kashi_rt_glyph_row(id, idx, row);
                if (rv < 0) { return 7; }
                if (rv > 0xFF) { return 8; }
                if (idx >= count) {
                    if (rv != 0) { return 9; }
                }
                if (row >= height) {
                    if (rv != 0) { return 10; }
                }
                var cp = rng_next() & 0xFFFFF;
                var cv = kashi_font_row(id, cp, row);
                if (cv < 0) { return 11; }
                if (cv > 0xFF) { return 12; }
                g = g + 1;
            }
        }
        r = r + 1;
    }
    return 0;
}

# --- PCF parser fuzz (0.7.1) ---
#
# PCF is the biggest untrusted-input surface kashi has so far — table-of-
# contents with offsets, signed metric biases, variable-length encodings,
# format-byte combinatorics, per-row bit-reverse and scan-unit byte-swap
# paths. Same four pick paths as fuzz_bdf.

fn _fz_pcf_put32(buf, off, v) {
    store8(buf + off + 0, v & 0xFF);
    store8(buf + off + 1, (v >> 8) & 0xFF);
    store8(buf + off + 2, (v >> 16) & 0xFF);
    store8(buf + off + 3, (v >> 24) & 0xFF);
    return 0;
}

# Build a small valid 2-glyph PCF into `buf`. Used by fuzz_pcf for the
# template / mutated / truncated paths.
fn _fz_pcf_template(buf) {
    store8(buf + 0, 0x01); store8(buf + 1, 0x66);
    store8(buf + 2, 0x63); store8(buf + 3, 0x70);
    _fz_pcf_put32(buf, 4, 3);
    var moff = 56;
    var msize = 4 + 2 + 2 * 5;
    _fz_pcf_put32(buf, 8, 0x04);
    _fz_pcf_put32(buf, 12, 0x108);
    _fz_pcf_put32(buf, 16, msize);
    _fz_pcf_put32(buf, 20, moff);
    var boff = moff + msize;
    var bsize = 4 + 4 + 2 * 4 + 16 + 2 * 8;
    _fz_pcf_put32(buf, 24, 0x08);
    _fz_pcf_put32(buf, 28, 0x08);
    _fz_pcf_put32(buf, 32, bsize);
    _fz_pcf_put32(buf, 36, boff);
    var eoff = boff + bsize;
    var esize = 4 + 5 * 2 + 2 * 2;
    _fz_pcf_put32(buf, 40, 0x20);
    _fz_pcf_put32(buf, 44, 0x08);
    _fz_pcf_put32(buf, 48, esize);
    _fz_pcf_put32(buf, 52, eoff);
    _fz_pcf_put32(buf, moff, 0x108);
    store8(buf + moff + 4, 2); store8(buf + moff + 5, 0);
    var mi = 0;
    while (mi < 2) {
        var s = moff + 6 + mi * 5;
        store8(buf + s + 0, 0x80);
        store8(buf + s + 1, 0x88);
        store8(buf + s + 2, 0x88);
        store8(buf + s + 3, 0x88);
        store8(buf + s + 4, 0x80);
        mi = mi + 1;
    }
    _fz_pcf_put32(buf, boff, 0x08);
    _fz_pcf_put32(buf, boff + 4, 2);
    _fz_pcf_put32(buf, boff + 8, 0);
    _fz_pcf_put32(buf, boff + 12, 8);
    _fz_pcf_put32(buf, boff + 16, 16);
    _fz_pcf_put32(buf, boff + 20, 48);
    _fz_pcf_put32(buf, boff + 24, 96);
    _fz_pcf_put32(buf, boff + 28, 192);
    var bd = boff + 32;
    var bi = 0;
    while (bi < 16) { store8(buf + bd + bi, 0x55); bi = bi + 1; }
    _fz_pcf_put32(buf, eoff, 0x08);
    store8(buf + eoff + 4, 0x41); store8(buf + eoff + 5, 0);
    store8(buf + eoff + 6, 0x42); store8(buf + eoff + 7, 0);
    store8(buf + eoff + 8, 0); store8(buf + eoff + 9, 0);
    store8(buf + eoff + 10, 0); store8(buf + eoff + 11, 0);
    store8(buf + eoff + 12, 0); store8(buf + eoff + 13, 0);
    store8(buf + eoff + 14, 0); store8(buf + eoff + 15, 0);
    store8(buf + eoff + 16, 1); store8(buf + eoff + 17, 0);
    return eoff + esize;
}

fn fuzz_pcf(rounds) {
    var cap = 2048;
    var buf = alloc(cap);
    var hdr[56];
    var ctx[144];
    var dest[128];
    var r = 0;
    while (r < rounds) {
        var pick = rng_next() & 3;
        var len = 0;
        if (pick == 0) {
            len = rng_next() % (cap + 1);
            var i = 0;
            while (i < len) {
                store8(buf + i, rng_next() & 0xFF);
                i = i + 1;
            }
            # Sometimes stamp a real magic so the fuzzer reaches table-validation.
            if ((rng_next() & 1) == 1) {
                if (len >= 4) {
                    store8(buf + 0, 0x01); store8(buf + 1, 0x66);
                    store8(buf + 2, 0x63); store8(buf + 3, 0x70);
                }
            }
        }
        if (pick == 1) {
            len = _fz_pcf_template(buf);
        }
        if (pick == 2) {
            len = _fz_pcf_template(buf);
            var muts = (rng_next() & 7) + 1;
            var m = 0;
            while (m < muts) {
                var off = rng_next() % len;
                store8(buf + off, rng_next() & 0xFF);
                m = m + 1;
            }
        }
        if (pick == 3) {
            len = _fz_pcf_template(buf);
            len = rng_next() % (len + 1);
        }

        # Contract 1: parser only returns a known code, never crashes.
        var rc = kashi_pcf_parse_header(buf, len, &hdr, &ctx);
        if (rc != KASHI_PCF_OK) {
            if (rc != KASHI_PCF_EINVAL) {
                if (rc != KASHI_PCF_EFORMAT) { return 1; }
            }
        }

        # Contract 2: if parse accepted, decode_glyph and cp_to_idx are
        # bounds-safe for random inputs.
        if (rc == KASHI_PCF_OK) {
            var count = load64(&ctx + PCF_CTX_GLYPH_COUNT);
            var g = 0;
            while (g < 3) {
                var gi = rng_next() % (count + 2);
                var grc = kashi_pcf_decode_glyph(buf, &ctx, gi, &dest, 128);
                if (grc != KASHI_PCF_OK) {
                    if (grc != KASHI_PCF_EINVAL) {
                        if (grc != KASHI_PCF_EFORMAT) { return 2; }
                    }
                }
                var cp = rng_next() & 0xFFFFF;
                var idx = kashi_pcf_cp_to_idx(buf, &ctx, cp);
                if (idx < 0 - 1) { return 3; }
                if (idx >= count) {
                    if (idx != 0 - 1) { return 4; }
                }
                g = g + 1;
            }
        }

        # Contract 3: kashi_load_pcf returns a value; an accepted font is
        # bounds-safe under random probes (same posture as fuzz_bdf).
        var id = kashi_load_pcf(buf, len);
        if (id >= KASHI_RT_FONT_BASE) {
            var c2 = kashi_rt_font_count(id);
            var h2 = kashi_rt_font_height(id);
            var pr = 0;
            while (pr < 3) {
                var row = rng_next() & 0xFF;
                var idx2 = rng_next() % (c2 + 2);
                var rv = kashi_rt_glyph_row(id, idx2, row);
                if (rv < 0) { return 5; }
                if (rv > 0xFF) { return 6; }
                if (idx2 >= c2) {
                    if (rv != 0) { return 7; }
                }
                if (row >= h2) {
                    if (rv != 0) { return 8; }
                }
                var cp2 = rng_next() & 0xFFFFF;
                var cv = kashi_font_row(id, cp2, row);
                if (cv < 0) { return 9; }
                if (cv > 0xFF) { return 10; }
                pr = pr + 1;
            }
        }
        r = r + 1;
    }
    return 0;
}

fn main() {
    alloc_init();
    kashi_font_init();

    # A couple of canned seeds so the harness self-checks under `cyrius run`.
    var seed[4];
    store8(&seed + 0, KASHI_FONT_VGA_8X16);
    store8(&seed + 1, 0x41);
    store8(&seed + 2, 5);
    store8(&seed + 3, 0);
    if (fuzz_main(&seed, 3) != 0) { println("fuzz: FAIL seed1"); return 1; }

    store8(&seed + 0, 99);     # unknown font
    store8(&seed + 1, 0x09);   # control char (unencoded)
    store8(&seed + 2, 200);    # out-of-range row
    if (fuzz_main(&seed, 3) != 0) { println("fuzz: FAIL seed2"); return 1; }

    # PSF parser fuzz: thousands of random/truncated/mutated buffers.
    rng_seed(0x9E3779B97F4A7C15);
    var pr = fuzz_psf(4000);
    if (pr != 0) { println("fuzz: FAIL psf"); return pr; }

    # BDF parser fuzz: text-based parser, four pick paths.
    rng_seed(0xD1B54A32D192ED03);
    var br = fuzz_bdf(2000);
    if (br != 0) { println("fuzz: FAIL bdf"); return br; }

    # PCF parser fuzz: TOC-driven binary parser; biggest input surface.
    rng_seed(0xA1B2C3D4E5F60718);
    var cr = fuzz_pcf(1500);
    if (cr != 0) { println("fuzz: FAIL pcf"); return cr; }

    println("fuzz: ok");
    return 0;
}

var r = main();
syscall(60, r);
